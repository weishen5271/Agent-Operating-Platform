{
  "package_id": "industry.mfg_maintenance",
  "name": "制造业设备运维助手",
  "version": "v1.0.0",
  "owner": "智能制造方案组",
  "domain": "industry",
  "description": "面向离散制造与流程行业的设备运维场景，覆盖故障诊断、SOP 检索、点检巡检、备件采购与停机分析。提供面向产线工程师与设备主管的多轮问答与决策支持。",

  "intents": [
    {
      "name": "work_order_query",
      "score": 0.94,
      "keywords": ["维修工单", "工单信息", "历史工单", "维修记录", "工单记录", "看一下工单", "查询工单", "工单"]
    },
    {
      "name": "knowledge_query",
      "score": 0.65,
      "keywords": ["SOP", "点检", "巡检", "报警说明", "停机说明", "异常说明", "告警代码", "处理步骤", "维修手册"]
    },
    {
      "name": "fault_diagnosis",
      "score": 0.88,
      "keywords": ["诊断", "排查", "根因", "为什么", "怎么办", "电机过热", "振动异常", "压力超限", "传感器漂移"]
    },
    {
      "name": "procurement_draft",
      "score": 0.8,
      "keywords": ["采购", "备件", "替换", "供应商", "BOM", "轴承", "皮带", "滤芯", "传感器更换"]
    },
    {
      "name": "maintenance_plan",
      "score": 0.78,
      "keywords": ["保养计划", "PM", "预防性维护", "周保", "月保", "年检", "停机窗口", "排程", "工单"]
    },
    {
      "name": "downtime_analysis",
      "score": 0.75,
      "keywords": ["OEE", "停机率", "MTBF", "MTTR", "可用率", "停机分析", "效率", "瓶颈"]
    }
  ],

  "business_objects": [
    {
      "type": "equipment",
      "label": "设备",
      "id_field": "equipment_id",
      "lookup_capability": ""
    }
  ],

  "ai_actions": [
    {
      "id": "equipment_fault_analysis",
      "label": "故障分析",
      "description": "查询报警、历史工单和知识库，生成故障原因分析与处置建议。",
      "object_types": ["equipment"],
      "skill": "fault_triage",
      "required_inputs": ["equipment_id"],
      "optional_inputs": ["fault_code", "last_n", "query"],
      "outputs": ["recommendation", "action_plan"],
      "risk_level": "low",
      "requires_confirmation": false,
      "data_input_modes": ["platform_pull"]
    }
  ],

  "requires": [
    {
      "kind": "common_package",
      "name": "_common/knowledge",
      "version_range": ">=1.0 <2.0"
    },
    {
      "kind": "common_package",
      "name": "_common/report_gen",
      "version_range": ">=0.5"
    },
    {
      "kind": "platform_skill",
      "name": "kb_grounded_qa",
      "version_range": ">=1.2 <2.0"
    },
    {
      "kind": "platform_skill",
      "name": "report_compose",
      "version_range": ">=0.5 <1.0"
    }
  ],

  "provides": {
    "skills": [
      "skills/work_order_history_query.json",
      "skills/fault_triage.json",
      "skills/spare_lookup_with_alt.json"
    ],
    "tools": [
      "tools/dispatch_summary.json"
    ],
    "plugins": [
      "plugins/cmms_work_order/plugin.json",
      "plugins/scada_alarm_query/plugin.json",
      "plugins/spare_parts_catalog/plugin.json"
    ]
  },

  "prompts": {
    "system": "prompts/system_prompt.txt",
    "planner": "prompts/planner_prompt.txt"
  },

  "knowledge_bindings": [
    {
      "source": "equipment_sop",
      "label": "设备 SOP 手册",
      "description": "按设备型号归档的标准作业指导书与维修手册。",
      "filters": ["equipment_id", "model", "vendor"]
    },
    {
      "source": "fault_codes",
      "label": "故障代码库",
      "description": "PLC / SCADA 报警代码的解释与处置建议。",
      "filters": ["code", "severity"]
    },
    {
      "source": "maintenance_logs",
      "label": "历史维修工单",
      "description": "脱敏后的历史工单与处置记录，用于 RAG 检索类似案例。",
      "filters": ["equipment_id", "fault_type", "year"]
    }
  ],

  "default_outputs": ["report", "recommendation", "action_plan"]
}
